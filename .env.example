COMPOSE_PROJECT_NAME=desafio-clarke
HTTP_PORT=80
HTTPS_PORT=443
SERVER_NAME=localhost
TLS_CERT_FILENAME=selfsigned.crt
TLS_KEY_FILENAME=selfsigned.key
CERT_VALID_DAYS=365
API_PREFIX=/api/v1
NEXT_PUBLIC_API_URL=https://web.localhost/api/v1
POSTGRES_DB=clarke
POSTGRES_USER=clarke
POSTGRES_PASSWORD=clarke
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://clarke:clarke@postgres:5432/clarke
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=public
MINIO_PUBLIC_ENDPOINT=https://minio.localhost
PUBLIC_ASSETS_BASE_URL=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
